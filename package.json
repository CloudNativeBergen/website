{
  "name": "cloud-native-bergen",
  "version": "2025.10.30",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:clean": "rm -rf .next && pnpm run build",
    "start": "next start",
    "check": "concurrently -n typecheck,lint,knip,format -c blue,green,yellow,magenta --kill-others-on-fail \"pnpm run typecheck\" \"pnpm run lint\" \"pnpm run knip\" \"pnpm run format\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "test": "vitest run",
    "test:debug": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:badges": "vitest run __tests__/lib/badge/",
    "format:check": "prettier --cache --check .",
    "format": "prettier --cache --write --list-different .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-storybook:test": "storybook build --test",
    "storybook:test": "test-storybook --maxWorkers=50%",
    "storybook:test-ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"pnpm build-storybook:test --quiet && npx http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && pnpm storybook:test\"",
    "qodo": "qodo",
    "qodo:chat": "qodo chat",
    "qodo:review": "qodo merge",
    "sanity": "sanity",
    "manage-orphaned-files": "tsx scripts/manage-orphaned-files.ts",
    "analyze-code": "tsx scripts/analyze-code-lines.ts"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@headlessui/tailwindcss": "^0.2.2",
    "@heroicons/react": "^2.2.0",
    "@next/eslint-plugin-next": "^16.2.1",
    "@noble/ed25519": "^3.0.1",
    "@portabletext/editor": "^6.5.2",
    "@portabletext/react": "^6.0.3",
    "@portabletext/to-html": "^5.0.2",
    "@portabletext/types": "^4.0.2",
    "@react-email/render": "^2.0.4",
    "@react-pdf/renderer": "^4.3.2",
    "@sanity/image-url": "^2.1.0",
    "@sanity/types": "^5.18.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.2",
    "@vercel/speed-insights": "^2.0.0",
    "@workos-inc/authkit-nextjs": "^3.0.0",
    "apexcharts": "^5.10.4",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "html2canvas-pro": "^2.0.2",
    "jose": "^6.2.2",
    "jsonld": "^9.0.0",
    "nanoid": "^5.1.7",
    "next": "^16.2.1",
    "next-auth": "5.0.0-beta.30",
    "next-sanity": "^12.2.1",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "qr-code-styling": "^1.9.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "resend": "^6.9.4",
    "sanity": "^5.18.0",
    "signature_pad": "^5.1.3",
    "speakingurl": "^14.0.1",
    "styled-components": "^6.3.12",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@qodo/command": "^0.36.0",
    "@sanity/client": "^7.20.0",
    "@sanity/migrate": "^6.1.1",
    "@sanity/vision": "^5.19.0",
    "@starefossen/sanity-plugin-inline-svg-input": "^1.3.7",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonld": "^1.5.15",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.27",
    "chromatic": "^16.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "glob": "^13.0.6",
    "http-server": "^14.1.1",
    "knip": "^6.3.0",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check && pnpm run test"
  }
}
