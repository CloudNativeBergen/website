{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/page.{ts,tsx}",
    "src/app/**/layout.{ts,tsx}",
    "src/app/**/route.{ts,tsx}",
    "src/app/**/loading.{ts,tsx}",
    "src/app/**/not-found.{ts,tsx}",
    "src/proxy.{ts,tsx}",
    "src/server/routers/**/*.ts",
    "sanity/actions/**/*.js",
    "scripts/**/*.ts",
    "migrations/**/index.ts",
    "src/**/*.stories.{ts,tsx}",
    "src/docs/**/*.{ts,tsx}",
    ".storybook/**/*.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx,js,jsx}",
    "sanity/**/*.{ts,tsx,js,jsx}",
    ".storybook/**/*.{ts,tsx,js,jsx}",
    "!src/**/*.test.{ts,tsx}",
    "!**/__tests__/**"
  ],
  "ignore": [
    "src/components/examples/**",
    "sanity/**",
    "migrations/**",
    "src/lib/empty-module.ts",
    "src/components/admin/dashboard/widgets/__matrix__/mock-admin-actions.ts",
    "src/lib/sponsor-crm/contract-send.ts"
  ],
  "ignoreDependencies": ["eslint-config-next", "ts-node", "chromatic", "@workos-inc/node"],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true
}
